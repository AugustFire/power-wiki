{
  "name": "power-wiki",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Confluence-style team knowledge base — Vue 3 frontend + Hono/Postgres backend monorepo",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm -F web dev",
    "dev:api": "pnpm -F api dev",
    "build": "pnpm -r build",
    "preview": "pnpm -F web preview",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist .vite .tmp node_modules/.cache"
  },
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
