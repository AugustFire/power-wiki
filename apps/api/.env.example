# apps/api runtime config — copy to apps/api/.env and adjust as needed.
# apps/api/.env is gitignored; do not commit secrets.

# Postgres connection string. Matches docker-compose.yml default user/pass/db.
DATABASE_URL=postgres://power_wiki:power_wiki_dev@127.0.0.1:5432/power_wiki

# Hono listen port (apps/web/vite.config.ts proxies /api to this port).
PORT=8787

# Comma-separated list of allowed origins for CORS. Dev default is the Vite port.
CORS_ORIGIN=http://127.0.0.1:5173

# ─── Stage 4: Admin bootstrap ────────────────────────────────────────────────
# REQUIRED on first boot when the users table is empty. The API will refuse to
# start without these (admin bootstrap fails fast with a clear error message).
# After the first user is created, these env vars are ignored.
#
# Production guidance:
#   - Set a strong password (≥ 8 chars, mix letters + digits)
#   - The admin can reset their own password later via the /reset-password flow,
#     but only after first signing in with the env-var password.
ADMIN_EMAIL=admin@power-wiki.local
ADMIN_PASSWORD=admin123

# ─── Object storage (MinIO, dev + prod 共套) ─────────────────────────────
# 主机 dev 用 http://127.0.0.1:9100(docker-compose 把容器 9000 映射到 9100,避 Windows
# 上 9000 被 VMware NAT 等占用);容器内 API 用 http://minio:9000(docker 网络)。
# 上传走 presigned PUT(浏览器直传 MinIO),下载走 API 流式代理。
S3_ENDPOINT=http://127.0.0.1:9100
S3_REGION=us-east-1                       # SDK 必填,MinIO 不校验
S3_BUCKET=power-wiki-attachments
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true                  # MinIO 强制 path-style,AWS S3 可改 false
S3_PRESIGN_EXPIRES_SEC=900                # presign TTL,15 min

# 单次上传字节上限。FinalizeUploadInputSchema 也用 MAX_UPLOAD_BYTES_DEFAULT 兜底。
MAX_UPLOAD_BYTES=20971520                 # 20 MB
